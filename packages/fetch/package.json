{
  "name": "@xrequest/fetch",
  "version": "1.0.0",
  "description": "Fetch API engine implementation for xRequest",
  "keywords": [
    "xrequest",
    "http",
    "request",
    "ajax",
    "fetch",
    "fetch-api"
  ],
  "author": {
    "name": "xRequest Team",
    "url": "https://github.com/xrequest"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xrequest/xrequest.git",
    "directory": "packages/fetch"
  },
  "homepage": "https://github.com/xrequest/xrequest#readme",
  "bugs": {
    "url": "https://github.com/xrequest/xrequest/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@xrequest/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "peerDependencies": {
    "@xrequest/core": "workspace:*",
    "typescript": ">=5.0.0"
  }
}