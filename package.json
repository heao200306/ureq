{
  "name": "xrequest-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "A lightweight HTTP request library with dual-engine support (XHR & Fetch) based on pnpm monorepo architecture",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "build:core": "pnpm --filter @xrequest/core build",
    "build:xhr": "pnpm --filter @xrequest/xhr build",
    "build:fetch": "pnpm --filter @xrequest/fetch build",
    "build:entry": "pnpm --filter @xrequest/entry build",
    "build:main": "pnpm --filter xrequest build",
    "dev": "pnpm -r --parallel run dev",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "typecheck": "pnpm -r run typecheck",
    "prepare": "husky install",
    "release": "bumpp --commit --tag --push",
    "release:major": "bumpp --commit --tag --push --major",
    "release:minor": "bumpp --commit --tag --push --minor",
    "release:patch": "bumpp --commit --tag --push --patch"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitest/coverage-v8": "^1.2.0",
    "@vitest/ui": "^1.2.0",
    "bumpp": "^9.4.0",
    "eslint": "^8.56.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@8.15.0"
}